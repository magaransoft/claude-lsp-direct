#!/usr/bin/env bash
# sbt-direct — per-workspace sbt coordinator. Each /call runs sbt
# <task> as a one-shot subprocess (no persistent JVM in v1 — see
# docs/per-language/sbt.md for the tradeoff).
# subcommands: start [workspace] | call <method> <json-params> [workspace] | stop [workspace] | status | tools [workspace]
set -euo pipefail

STATE_ROOT="${SBT_DIRECT_STATE:-$HOME/.cache/sbt-direct}"
COORDINATOR="$HOME/.claude/bin/sbt-direct-coordinator.js"
WORKSPACE_MARKERS=(build.sbt build.sc build.mill project/build.properties)
# SBT_DIRECT_MODE=auto (default) | bsp | oneshot
#   auto: coordinator probes <workspace>/.bsp/sbt.json. If present → bsp
#         mode (warm calls <200ms). If absent → oneshot (20-40s per call),
#         with a log message telling the user to run `sbt bspConfig`.
#   bsp: force Build Server Protocol mode. Errors if .bsp/sbt.json absent.
#   oneshot: force per-call subprocess. Slower than bare sbt; kept as a
#            fallback for projects without BSP and as an integration test
#            path.
SBT_MODE="${SBT_DIRECT_MODE:-auto}"

die() { echo "sbt-direct: $*" >&2; exit 1; }

resolve_workspace() {
  local ws="${1:-}"
  if [ -n "$ws" ]; then ws="$(cd "$ws" && pwd)"; echo "$ws"; return; fi
  ws="$PWD"
  while [ "$ws" != "/" ]; do
    for marker in "${WORKSPACE_MARKERS[@]}"; do
      [ -e "$ws/$marker" ] && { echo "$ws"; return; }
    done
    ws="$(dirname "$ws")"
  done
  echo "$PWD"
}

state_dir() {
  local hash
  hash="$(printf '%s' "$1" | shasum | awk '{print $1}' | cut -c1-12)"
  echo "$STATE_ROOT/$hash"
}

free_port() {
  python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()'
}

state_get() { [ -f "$1/$2" ] && cat "$1/$2" || echo ""; }

port_ready() {
  curl -fsS -m 2 "http://127.0.0.1:$1/health" >/dev/null 2>&1
}

server_alive() {
  local port; port="$(state_get "$1" port)"
  [ -z "$port" ] && return 1
  port_ready "$port"
}

cmd_start() {
  command -v sbt >/dev/null || die "sbt not on PATH — install via sdkman ('sdk install sbt') or brew"
  [ -f "$COORDINATOR" ] || die "coordinator missing: $COORDINATOR"
  local ws dir port pid
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  mkdir -p "$dir"
  if server_alive "$dir"; then
    echo "already running: workspace=$ws port=$(state_get "$dir" port) pid=$(state_get "$dir" pid)"
    return 0
  fi
  port="$(free_port)"
  echo "$ws" > "$dir/workspace"
  echo "$port" > "$dir/port"
  nohup node "$COORDINATOR" --tool-name sbt-direct --mode "$SBT_MODE" --workspace "$ws" --port "$port" >"$dir/log" 2>&1 &
  pid=$!
  echo "$pid" > "$dir/pid"
  # bsp + auto modes wait for sbt JVM boot + BSP initialize (15-30s
  # warm, up to 120s on fresh ivy/coursier cache). Pure oneshot binds
  # immediately since no persistent child spawns.
  local timeout=30
  [ "$SBT_MODE" != "oneshot" ] && timeout=120
  local i=0
  until port_ready "$port"; do
    sleep 1
    i=$((i+1))
    [ "$i" -ge "$timeout" ] && { kill "$pid" 2>/dev/null; die "coordinator did not bind port $port within ${timeout}s — check $dir/log"; }
  done
  echo "started: workspace=$ws port=$port pid=$pid state=$dir"
}

cmd_call() {
  local method="${1:-}"; shift || true
  local params_json="${1-}"; shift || true
  [ -z "$params_json" ] && params_json='{}'
  [ -z "$method" ] && die "usage: sbt-direct call <method> '<json-params>' [workspace]"
  local ws dir port
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  server_alive "$dir" || { echo "server not running for $ws — starting..." >&2; cmd_start "$ws" >&2; }
  port="$(state_get "$dir" port)"
  local payload
  payload="$(jq -cn --arg method "$method" --argjson params "$params_json" '{method:$method,params:$params}')"
  curl -fsS -m 600 "http://localhost:$port/call" -X POST \
    -H 'Content-Type: application/json' \
    -d "$payload" || die "sbt call failed"
  echo
}

cmd_tools() {
  cat <<EOF
sbt-direct methods (current mode: $SBT_MODE):

oneshot mode (default) — per-call `sbt <task>` subprocess:

  version    sbt --version
  reload     sbt reload
  task       {task:"<name>", project?:"<module>"}

bsp mode (SBT_DIRECT_MODE=bsp) — persistent sbt via Build Server
Protocol. Prereq: run `sbt bspConfig` once in the workspace to
generate .bsp/sbt.json. Warm calls sub-second.

  version, build-targets   {}
  compile                  {target?: "<name>"|"<uri>"}   all targets if omitted
  test                     {target?, filter?: "<fqcn>"}
  run                      {target, args?: [string,...]}
  clean                    {target?}
  sources                  {target?}
  dependency-sources       {target?}
  reload                   {}  — workspace/reload

invoke:
  sbt-direct call task '{"task":"compile"}' [workspace]    # oneshot
  SBT_DIRECT_MODE=bsp sbt-direct call compile '{}' [ws]    # bsp
  sbt-direct call build-targets '{}' [workspace]           # bsp introspection

see docs/per-language/sbt.md for timing + invalidation matrix.
EOF
}

cmd_stop() {
  local ws dir pid
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  pid="$(state_get "$dir" pid)"
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null && echo "stopped: pid=$pid workspace=$ws" || echo "kill failed (pid=$pid) — state cleared for $ws"
  else
    echo "no pid for $ws"
  fi
  rm -f "$dir/pid" "$dir/port"
}

cmd_status() {
  [ -d "$STATE_ROOT" ] || { echo "no servers tracked"; return; }
  local any=0
  for dir in "$STATE_ROOT"/*/; do
    [ -d "$dir" ] || continue
    any=1
    local ws pid port alive
    ws="$(state_get "$dir" workspace)"
    pid="$(state_get "$dir" pid)"
    port="$(state_get "$dir" port)"
    alive="dead"
    [ -n "$port" ] && port_ready "$port" && alive="alive"
    printf 'workspace=%s  port=%s  pid=%s  %s\n' "$ws" "$port" "$pid" "$alive"
  done
  [ "$any" = 0 ] && echo "no servers tracked"
}

case "${1:-}" in
  start)  shift; cmd_start "$@" ;;
  call)   shift; cmd_call "$@" ;;
  tools)  shift; cmd_tools "$@" ;;
  stop)   shift; cmd_stop "$@" ;;
  status) shift; cmd_status "$@" ;;
  ""|-h|--help)
    cat <<EOF
sbt-direct — per-workspace sbt coordinator

usage:
  sbt-direct start [workspace]
  sbt-direct call task '{"task":"compile"}' [workspace]
  sbt-direct call reload '{}' [workspace]
  sbt-direct call version '{}' [workspace]
  sbt-direct tools
  sbt-direct stop [workspace]
  sbt-direct status

workspace markers (walk-up order): ${WORKSPACE_MARKERS[*]}

state: $STATE_ROOT/<workspace-hash>/{pid,port,workspace,log,calls.log,triggers.json}

see: docs/per-language/sbt.md for caveats (per-call cold-start; persistent-JVM adapter is follow-up work).
EOF
    ;;
  *) die "unknown subcommand: $1 (try --help)" ;;
esac
