#!/usr/bin/env bash
# vue-direct — bridge @vue/language-server + raw tsserver (w/ @vue/typescript-plugin) over persistent HTTP
# plugin-loader path blocked for v3 hybrid; out-of-band wrapper mirrors metals-direct
# subcommands: start [workspace] | call <method> <json-params> [workspace] | stop [workspace] | status | tools [workspace]
set -euo pipefail

STATE_ROOT="${VUE_DIRECT_STATE:-$HOME/.cache/vue-direct}"
COORDINATOR="$HOME/.claude/bin/vue-direct-coordinator.js"

die() { echo "vue-direct: $*" >&2; exit 1; }

# resolve workspace: arg > walk up for package.json > cwd
resolve_workspace() {
  local ws="${1:-}"
  if [ -n "$ws" ]; then
    ws="$(cd "$ws" && pwd)"
  else
    ws="$PWD"
    while [ "$ws" != "/" ]; do
      [ -e "$ws/package.json" ] && { echo "$ws"; return; }
      ws="$(dirname "$ws")"
    done
    ws="$PWD"
  fi
  echo "$ws"
}

# derive state dir from workspace hash — one slot per workspace
state_dir() {
  local ws="$1"
  local hash
  hash="$(printf '%s' "$ws" | shasum | awk '{print $1}' | cut -c1-12)"
  echo "$STATE_ROOT/$hash"
}

free_port() {
  python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()'
}

state_get() {
  local dir="$1" key="$2"
  [ -f "$dir/$key" ] && cat "$dir/$key" || echo ""
}

port_ready() {
  # HTTP /health probe — works under Claude's macOS sandbox where /dev/tcp + kill -0 are denied
  local port="$1"
  curl -fsS -m 2 "http://127.0.0.1:$port/health" >/dev/null 2>&1
}

server_alive() {
  local dir="$1"
  local port
  port="$(state_get "$dir" port)"
  [ -z "$port" ] && return 1
  port_ready "$port"
}

cmd_start() {
  command -v vue-language-server >/dev/null || die "vue-language-server not on PATH — install via 'npm i -g @vue/language-server@3.2.6 @vue/typescript-plugin@3.2.6 typescript@5.9.3'"
  [ -f "$COORDINATOR" ] || die "coordinator missing: $COORDINATOR"
  local ws dir pid port
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  mkdir -p "$dir"
  if server_alive "$dir"; then
    echo "already running: workspace=$ws port=$(state_get "$dir" port) pid=$(state_get "$dir" pid)"
    return 0
  fi
  port="$(free_port)"
  echo "$ws" > "$dir/workspace"
  echo "$port" > "$dir/port"
  nohup node "$COORDINATOR" --tool-name vue-direct --workspace "$ws" --port "$port" >"$dir/log" 2>&1 &
  pid=$!
  echo "$pid" > "$dir/pid"
  local i=0
  until port_ready "$port"; do
    sleep 1
    i=$((i+1))
    [ "$i" -ge 60 ] && { kill "$pid" 2>/dev/null; die "coordinator did not bind port $port within 60s — check $dir/log"; }
    kill -0 "$pid" 2>/dev/null || die "coordinator died at startup — check $dir/log"
  done
  echo "started: workspace=$ws port=$port pid=$pid state=$dir"
}

cmd_call() {
  local method="${1:-}"; shift || true
  local params_json="${1-}"; shift || true
  [ -z "$params_json" ] && params_json='{}'
  [ -z "$method" ] && die "usage: vue-direct call <method> '<json-params>' [workspace]"
  local ws dir port
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  server_alive "$dir" || { echo "server not running for $ws — starting..." >&2; cmd_start "$ws" >&2; }
  port="$(state_get "$dir" port)"
  local payload
  payload="$(jq -cn --arg method "$method" --argjson params "$params_json" '{method:$method,params:$params}')"
  curl -fsS -m 120 "http://localhost:$port/lsp" -X POST \
    -H 'Content-Type: application/json' \
    -d "$payload" || die "lsp call failed"
  echo
}

cmd_tools() {
  cat <<EOF
vue-direct exposes raw LSP methods — send via: vue-direct call <method> '<json-params>' [workspace]

common methods (LSP 3.17 subset the Vue LS implements):
  textDocument/documentSymbol       outline of a .vue file
  textDocument/hover                type + doc at position
  textDocument/definition           jump to definition
  textDocument/references           find references
  textDocument/implementation       find implementers
  textDocument/typeDefinition       jump to type
  textDocument/completion           completions at position
  textDocument/signatureHelp        call signature
  textDocument/prepareCallHierarchy get call-hierarchy handle
  callHierarchy/incomingCalls       callers
  callHierarchy/outgoingCalls       callees
  textDocument/foldingRange         fold ranges
  textDocument/semanticTokens/full  semantic token colors
  workspace/symbol                  fuzzy search across workspace

all methods accept params per LSP spec. params MUST include textDocument.uri as file://<abs-path> for textDocument/* methods.

example:
  vue-direct call textDocument/documentSymbol '{"textDocument":{"uri":"file:///path/to/File.vue"}}'
EOF
}

cmd_stop() {
  local ws dir pid
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  pid="$(state_get "$dir" pid)"
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null && echo "stopped: pid=$pid workspace=$ws" || echo "kill failed (pid=$pid) — state cleared for $ws"
  else
    echo "no pid for $ws"
  fi
  rm -f "$dir/pid" "$dir/port"
}

cmd_status() {
  [ -d "$STATE_ROOT" ] || { echo "no servers tracked"; return; }
  local any=0
  for dir in "$STATE_ROOT"/*/; do
    [ -d "$dir" ] || continue
    any=1
    local ws pid port alive
    ws="$(state_get "$dir" workspace)"
    pid="$(state_get "$dir" pid)"
    port="$(state_get "$dir" port)"
    alive="dead"
    [ -n "$port" ] && port_ready "$port" && alive="alive"
    printf 'workspace=%s  port=%s  pid=%s  %s\n' "$ws" "$port" "$pid" "$alive"
  done
  [ "$any" = 0 ] && echo "no servers tracked"
}

case "${1:-}" in
  start)  shift; cmd_start "$@" ;;
  call)   shift; cmd_call "$@" ;;
  tools)  shift; cmd_tools "$@" ;;
  stop)   shift; cmd_stop "$@" ;;
  status) shift; cmd_status "$@" ;;
  ""|-h|--help)
    cat <<EOF
vue-direct — bridge @vue/language-server to raw tsserver w/ @vue/typescript-plugin over persistent HTTP

usage:
  vue-direct start [workspace]                 spawn coordinator for workspace (default: cwd walking up for package.json)
  vue-direct call <method> '<json-params>' [ws]  issue raw LSP method — auto-starts server if needed
  vue-direct tools                             list LSP method surface
  vue-direct stop [workspace]                  kill server for workspace
  vue-direct status                            show all tracked servers

examples:
  cd ~/projects/your-vue-app && vue-direct start
  vue-direct call textDocument/documentSymbol '{"textDocument":{"uri":"file:///path/to/File.vue"}}'
  vue-direct call textDocument/hover '{"textDocument":{"uri":"file:///path/to/File.vue"},"position":{"line":10,"character":5}}'

state: $STATE_ROOT/<workspace-hash>/{pid,port,workspace,log}
EOF
    ;;
  *) die "unknown subcommand: $1 (try --help)" ;;
esac
