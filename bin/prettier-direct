#!/usr/bin/env bash
# prettier-direct — per-workspace prettier daemon. In-process Node
# library (no child process); preload cost ~100ms, warm calls <50ms.
# subcommands: start [workspace] | call <method> <json-params> [workspace] | stop [workspace] | status | tools [workspace]
set -euo pipefail

STATE_ROOT="${PRETTIER_DIRECT_STATE:-$HOME/.cache/prettier-direct}"
DAEMON="$HOME/.claude/bin/prettier-direct-daemon.js"
WORKSPACE_MARKERS=(.prettierrc .prettierrc.json .prettierrc.js .prettierrc.cjs .prettierrc.mjs prettier.config.js prettier.config.cjs prettier.config.mjs package.json)

die() { echo "prettier-direct: $*" >&2; exit 1; }

resolve_workspace() {
  local ws="${1:-}"
  if [ -n "$ws" ]; then ws="$(cd "$ws" && pwd)"; echo "$ws"; return; fi
  ws="$PWD"
  while [ "$ws" != "/" ]; do
    for marker in "${WORKSPACE_MARKERS[@]}"; do
      [ -e "$ws/$marker" ] && { echo "$ws"; return; }
    done
    ws="$(dirname "$ws")"
  done
  echo "$PWD"
}

state_dir() {
  local hash
  hash="$(printf '%s' "$1" | shasum | awk '{print $1}' | cut -c1-12)"
  echo "$STATE_ROOT/$hash"
}

free_port() {
  python3 -c 'import socket; s=socket.socket(); s.bind(("",0)); print(s.getsockname()[1]); s.close()'
}

state_get() { [ -f "$1/$2" ] && cat "$1/$2" || echo ""; }

port_ready() {
  curl -fsS -m 2 "http://127.0.0.1:$1/health" >/dev/null 2>&1
}

server_alive() {
  local port; port="$(state_get "$1" port)"
  [ -z "$port" ] && return 1
  port_ready "$port"
}

cmd_start() {
  # verify prettier is resolvable from somewhere (workspace node_modules
  # or global); daemon's preload() does the actual require.
  [ -f "$DAEMON" ] || die "daemon missing: $DAEMON"
  local ws dir port pid
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  mkdir -p "$dir"
  if server_alive "$dir"; then
    echo "already running: workspace=$ws port=$(state_get "$dir" port) pid=$(state_get "$dir" pid)"
    return 0
  fi
  port="$(free_port)"
  echo "$ws" > "$dir/workspace"
  echo "$port" > "$dir/port"
  nohup node "$DAEMON" --tool-name prettier-direct --workspace "$ws" --port "$port" >"$dir/log" 2>&1 &
  pid=$!
  echo "$pid" > "$dir/pid"
  local i=0
  until port_ready "$port"; do
    sleep 1
    i=$((i+1))
    [ "$i" -ge 10 ] && { kill "$pid" 2>/dev/null; die "daemon did not bind port $port within 10s — check $dir/log"; }
  done
  echo "started: workspace=$ws port=$port pid=$pid state=$dir"
}

cmd_call() {
  local method="${1:-}"; shift || true
  local params_json="${1-}"; shift || true
  [ -z "$params_json" ] && params_json='{}'
  [ -z "$method" ] && die "usage: prettier-direct call <method> '<json-params>' [workspace]"
  local ws dir port
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  server_alive "$dir" || { echo "daemon not running for $ws — starting..." >&2; cmd_start "$ws" >&2; }
  port="$(state_get "$dir" port)"
  local payload
  payload="$(jq -cn --arg method "$method" --argjson params "$params_json" '{method:$method,params:$params}')"
  curl -fsS -m 120 "http://localhost:$port/call" -X POST \
    -H 'Content-Type: application/json' \
    -d "$payload" || die "prettier call failed"
  echo
}

cmd_tools() {
  cat <<EOF
prettier-direct methods (in-process prettier — warm calls <50ms):

  version        prettier.version
                 params: {}
  format         prettier.format(source, options)
                 params: { source: "<code>", filepath?: "<path>", options?: {...} }
  check          prettier.check(source, options)
                 params: { source: "<code>", filepath?: "<path>", options?: {...} }
  format-file    read file, prettier.resolveConfig, prettier.format; returns {changed, formatted}
                 params: { filepath: "<abs-path>" }
  resolve-config prettier.resolveConfig(filepath)
                 params: { filepath: "<abs-path>" }

invoke:
  prettier-direct call format-file '{"filepath":"/abs/path/file.ts"}'
  prettier-direct call format '{"source":"const x=1","filepath":"x.ts"}'
EOF
}

cmd_stop() {
  local ws dir pid
  ws="$(resolve_workspace "${1:-}")"
  dir="$(state_dir "$ws")"
  pid="$(state_get "$dir" pid)"
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null && echo "stopped: pid=$pid workspace=$ws" || echo "kill failed (pid=$pid) — state cleared for $ws"
  else
    echo "no pid for $ws"
  fi
  rm -f "$dir/pid" "$dir/port"
}

cmd_status() {
  [ -d "$STATE_ROOT" ] || { echo "no daemons tracked"; return; }
  local any=0
  for dir in "$STATE_ROOT"/*/; do
    [ -d "$dir" ] || continue
    any=1
    local ws pid port alive
    ws="$(state_get "$dir" workspace)"
    pid="$(state_get "$dir" pid)"
    port="$(state_get "$dir" port)"
    alive="dead"
    [ -n "$port" ] && port_ready "$port" && alive="alive"
    printf 'workspace=%s  port=%s  pid=%s  %s\n' "$ws" "$port" "$pid" "$alive"
  done
  [ "$any" = 0 ] && echo "no daemons tracked"
}

case "${1:-}" in
  start)  shift; cmd_start "$@" ;;
  call)   shift; cmd_call "$@" ;;
  tools)  shift; cmd_tools "$@" ;;
  stop)   shift; cmd_stop "$@" ;;
  status) shift; cmd_status "$@" ;;
  ""|-h|--help)
    cat <<EOF
prettier-direct — per-workspace prettier daemon

usage:
  prettier-direct start [workspace]
  prettier-direct call <method> '<json-params>' [workspace]
  prettier-direct tools
  prettier-direct stop [workspace]
  prettier-direct status

state: $STATE_ROOT/<workspace-hash>/{pid,port,workspace,log,calls.log,triggers.json}
install: prefer workspace-local via pnpm/npm; global fallback via 'npm i -g prettier'.
EOF
    ;;
  *) die "unknown subcommand: $1 (try --help)" ;;
esac
